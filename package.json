{
    "name": "Playwright-Scaffold-AI-Assisted-Development",
    "version": "1.0.0",
    "description": "A production-ready Playwright Scaffold for AI-assisted test automation framework development with TypeScript",
    "scripts": {
        "test": "npx playwright test --grep-invert @destructive",
        "test:chromium": "npx playwright test --project=chromium --grep-invert @destructive",
        "test:firefox": "npx playwright test --project=firefox --grep-invert @destructive",
        "test:webkit": "npx playwright test --project=webkit --grep-invert @destructive",
        "test:ci": "npx playwright test --project=chromium --workers=1",
        "test:debug": "npx playwright test --project=chromium --debug",
        "test:ui": "npx playwright test --project=chromium --ui",
        "test:headed": "npx playwright test --project=chromium --headed --grep-invert @destructive",
        "test:smoke": "npx playwright test --grep @smoke --project=chromium",
        "test:sanity": "npx playwright test --grep @sanity --project=chromium",
        "test:regression": "npx playwright test --grep @regression --project=chromium",
        "test:api": "npx playwright test --grep @api --project=chromium",
        "test:e2e": "npx playwright test --grep @e2e --project=chromium",
        "test:destructive": "npx playwright test --grep @destructive --project=chromium --workers=1",
        "report": "npx playwright show-report",
        "lint": "npx eslint .",
        "lint:fix": "npx eslint . --fix",
        "format": "npx prettier --write .",
        "setup": "bash scripts/setup.sh",
        "playwright-cli:install-browsers": "node scripts/install-playwright-cli-browsers.js",
        "setup:check": "node -e \"const v = +process.versions.node.split('.')[0]; if(v < 20) { console.error('Node >= 20 required, found ' + process.version); process.exit(1); }\" && bash scripts/link-cli.sh \"$PWD\" >/dev/null && playwright-cli --version && echo 'All checks passed'",
        "postinstall": "is-ci || husky"
    },
    "keywords": [],
    "author": "Ivan Davidov",
    "license": "MIT",
    "devDependencies": {
        "@faker-js/faker": "^9.9.0",
        "@playwright/cli": "^0.1.8",
        "@playwright/test": "^1.59.1",
        "@types/node": "^24.0.1",
        "@typescript-eslint/eslint-plugin": "^8.34.1",
        "@typescript-eslint/parser": "^8.34.1",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-define-config": "^2.1.0",
        "eslint-plugin-playwright": "^2.2.0",
        "eslint-plugin-prettier": "^5.5.0",
        "husky": "^9.1.7",
        "is-ci": "^4.1.0",
        "jiti": "^2.4.2",
        "lint-staged": "^16.1.2"
    },
    "dependencies": {
        "dotenv": "^16.5.0",
        "zod": "^4.3.6"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "npx eslint --fix",
            "npx prettier --write"
        ]
    }
}
